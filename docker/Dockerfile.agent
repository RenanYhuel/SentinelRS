FROM lukemathwalker/cargo-chef:latest-rust-bookworm AS chef
RUN apt-get update && apt-get install -y protobuf-compiler && rm -rf /var/lib/apt/lists/*
WORKDIR /build

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS builder
COPY --from=planner /build/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json
COPY . .
RUN cargo build --release --package sentinel_agent

FROM debian:bookworm-slim AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libssl3 curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r sentinel && useradd -r -g sentinel -s /sbin/nologin sentinel

COPY --from=builder /build/target/release/sentinel_agent /usr/local/bin/sentinel_agent

RUN mkdir -p /etc/sentinel /var/lib/sentinel/wal && chown -R sentinel:sentinel /etc/sentinel /var/lib/sentinel

VOLUME ["/etc/sentinel", "/var/lib/sentinel"]

USER sentinel

EXPOSE 9090

HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD curl -f http://localhost:9090/healthz || exit 1

LABEL org.opencontainers.image.title="SentinelRS Agent" \
      org.opencontainers.image.description="SentinelRS lightweight monitoring agent — metrics collector" \
      org.opencontainers.image.vendor="SentinelRS" \
      org.opencontainers.image.source="https://github.com/sentinelrs/sentinelrs"

ENTRYPOINT ["sentinel_agent"]
