# SentinelRS — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# ──────────────────────────────────────
# Global
# ──────────────────────────────────────
SENTINEL_VERSION=latest

# ──────────────────────────────────────
# TimescaleDB / PostgreSQL
# ──────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secret
POSTGRES_DB=sentinel
DATABASE_URL=postgres://sentinel:sentinel_secret@timescaledb:5432/sentinel

# ──────────────────────────────────────
# NATS
# ──────────────────────────────────────
NATS_URL=nats://nats:4222

# ──────────────────────────────────────
# Server
# ──────────────────────────────────────
SERVER_GRPC_PORT=50051
SERVER_REST_PORT=8080
SERVER_GRPC_ADVERTISE_ADDR=http://sentinel-server:50051
SERVER_LOG_LEVEL=info
SERVER_LOG_FORMAT=clean

# ──────────────────────────────────────
# Worker
# ──────────────────────────────────────
WORKER_LOG_LEVEL=info
WORKER_LOG_FORMAT=clean
WORKER_CONSUMER_GROUP=sentinel-workers

# ──────────────────────────────────────
# Agent
# ──────────────────────────────────────
SERVER_URL=http://sentinel-server:50051
AGENT_LOG_LEVEL=info
AGENT_LOG_FORMAT=clean
AGENT_COLLECT_INTERVAL=10
